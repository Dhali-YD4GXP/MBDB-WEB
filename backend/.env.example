# Server Config
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000

# Security
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production_vps

# Database Config (PostgreSQL or MySQL)
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mbdb_db
DB_SSLMODE=disable

# File Upload Location (Local Storage on VPS)
UPLOAD_DIR=./uploads/photos

# Initial Seeding Credentials (Only used when database is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminmbdb
