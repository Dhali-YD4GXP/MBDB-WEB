<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Do not rewrite existing static files or folders
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all other requests to index.php
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>
